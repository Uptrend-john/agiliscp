---
layout: layouts/base.njk
pageTitle: "Services"
pageDescription: "Advisory, IV&V, business process transformation, technology selection, project management, and organizational change management services."
permalink: /services/
---

<div class="page-header" id="services-header">
  <div class="container">
    <span class="section-label" style="color: var(--color-teal-light);">Our Capabilities</span>
    <h1>Services Built for <span class="accent">Complex Challenges</span></h1>
    <p>Six integrated practice areas tailored to drive measurable outcomes across every stage of your transformation journey.</p>
  </div>
</div>

<section class="section" id="services-list">
  <div class="container">
    {% for service in services %}
    <div class="service-detail animate-on-scroll" id="{{ service.id }}">
      <div class="service-detail__content">
        <h3>{{ service.title }}</h3>
        <p>{{ service.description }}</p>
        <h4 style="font-size: 0.9rem; color: var(--color-teal); margin-bottom: var(--space-md); text-transform: uppercase; letter-spacing: 0.08em;">Key Deliverables</h4>
        <ul class="service-detail__deliverables">
          {% for item in service.deliverables %}
          <li>{{ item }}</li>
          {% endfor %}
        </ul>
        <a href="/contact/?service={{ service.id }}" class="btn btn--outline" style="margin-top: var(--space-lg);">
          Discuss This Service <span class="arrow">→</span>
        </a>
      </div>
      <div class="service-detail__visual">
        {% if service.icon == "compass" %}
        <svg class="service-detail__icon-large" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>
        {% elif service.icon == "shield-check" %}
        <svg class="service-detail__icon-large" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
        {% elif service.icon == "refresh" %}
        <svg class="service-detail__icon-large" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2"/></svg>
        {% elif service.icon == "cpu" %}
        <svg class="service-detail__icon-large" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M15 2v2M15 20v2M2 15h2M2 9h2M20 15h2M20 9h2M9 2v2M9 20v2"/></svg>
        {% elif service.icon == "calendar" %}
        <svg class="service-detail__icon-large" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        {% elif service.icon == "users" %}
        <svg class="service-detail__icon-large" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        {% endif %}
      </div>
    </div>
    {% endfor %}
  </div>
</section>

<!-- CTA -->
<section class="section section--dark" style="padding: var(--space-4xl) 0;">
  <div class="container text-center">
    <h2 style="color: #fff; margin-bottom: var(--space-md);">Not Sure Where to Start?</h2>
    <p style="color: var(--color-text-on-dark-muted); font-size: 1.1rem; max-width: 550px; margin: 0 auto var(--space-xl);">
      Take our free assessment to identify your organization's biggest opportunities, or reach out for a no-obligation conversation.
    </p>
    <div style="display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap;">
      <a href="/assessment/" class="btn btn--primary btn--lg" id="services-assessment-cta">Take Free Assessment</a>
      <a href="/contact/" class="btn btn--secondary btn--lg" id="services-contact-cta">Contact Us</a>
    </div>
  </div>
</section>
