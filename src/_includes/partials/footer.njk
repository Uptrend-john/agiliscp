<footer class="footer" id="site-footer">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <a href="/" class="nav__logo" style="margin-bottom: var(--space-sm);">
          <span class="nav__logo-icon">A</span>
          <span>Agilis<span style="font-weight: 300; opacity: 0.7; margin-left: 4px;">CP</span></span>
        </a>
        <p>{{ site.tagline }}</p>
      </div>
      
      <div>
        <h4 class="footer__heading">Services</h4>
        <div class="footer__links">
          {% for service in services %}
          <a href="/services/#{{ service.id }}">{{ service.title }}</a>
          {% endfor %}
        </div>
      </div>
      
      <div>
        <h4 class="footer__heading">Company</h4>
        <div class="footer__links">
          <a href="/about/">About</a>
          <a href="/assessment/">Free Assessment</a>
          <a href="/insights/">Insights</a>
          <a href="/contact/">Contact</a>
        </div>
      </div>
      
      <div>
        <h4 class="footer__heading">Connect</h4>
        <div class="footer__links">
          <a href="mailto:{{ site.email }}">{{ site.email }}</a>
          <a href="{{ site.linkedin }}" target="_blank" rel="noopener">LinkedIn →</a>
          <a href="/contact/">Schedule a Consultation</a>
        </div>
      </div>
    </div>
    
    <div class="footer__bottom">
      <span>&copy; {{ 2026 }} {{ site.title }}, LLC. All rights reserved.</span>
      <span>{{ site.location }}</span>
    </div>
  </div>
</footer>
