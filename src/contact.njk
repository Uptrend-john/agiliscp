---
layout: layouts/base.njk
pageTitle: "Contact"
pageDescription: "Get in touch with Agilis Capability Partners to discuss your business transformation needs."
permalink: /contact/
---

<div class="page-header" id="contact-header">
  <div class="container">
    <span class="section-label" style="color: var(--color-teal-light);">Get in Touch</span>
    <h1>Let's Start a <span class="accent">Conversation</span></h1>
    <p>Whether you have a specific challenge or want to explore how we can help, we'd love to hear from you.</p>
  </div>
</div>

<section class="section" id="contact-section">
  <div class="container">
    <div class="contact-grid">
      <div>
        <h2 style="margin-bottom: var(--space-sm);">Send a Message</h2>
        <p style="margin-bottom: var(--space-xl);">Fill out the form below and Steve will respond within one business day.</p>
        
        <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" id="contact-form" action="/contact/success/">
          <input type="hidden" name="form-name" value="contact">
          <input type="hidden" name="assessment-score" id="assessment-score-field" value="">
          <p style="display:none;"><label>Don't fill this: <input name="bot-field"></label></p>
          
          <div class="form-row">
            <div class="form-group">
              <label for="contact-name">Full Name *</label>
              <input type="text" id="contact-name" name="name" required placeholder="Your full name">
            </div>
            <div class="form-group">
              <label for="contact-email">Email Address *</label>
              <input type="email" id="contact-email" name="email" required placeholder="you@company.com">
            </div>
          </div>
          
          <div class="form-row">
            <div class="form-group">
              <label for="contact-company">Company</label>
              <input type="text" id="contact-company" name="company" placeholder="Your organization">
            </div>
            <div class="form-group">
              <label for="contact-phone">Phone</label>
              <input type="tel" id="contact-phone" name="phone" placeholder="(555) 123-4567">
            </div>
          </div>
          
          <div class="form-group">
            <label for="contact-service">Service Interest</label>
            <select id="contact-service" name="service">
              <option value="">Select a service area...</option>
              <option value="advisory">Advisory Services</option>
              <option value="ivv">Independent Validation & Verification</option>
              <option value="process">Business Process Transformation</option>
              <option value="technology">Technology & Software Selection</option>
              <option value="project-management">Project Management</option>
              <option value="change-management">Organizational Change Management</option>
              <option value="general">General Inquiry</option>
            </select>
          </div>
          
          <div class="form-group">
            <label for="contact-message">Message *</label>
            <textarea id="contact-message" name="message" required placeholder="Tell us about your challenge or project..."></textarea>
          </div>
          
          <button type="submit" class="btn btn--primary btn--lg" id="contact-submit">
            Send Message <span class="arrow">→</span>
          </button>
        </form>
      </div>
      
      <div class="contact-info" id="contact-info-sidebar">
        <h3>Direct Contact</h3>
        
        <div class="contact-info__item">
          <div class="contact-info__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div class="contact-info__text">
            <strong>Email</strong>
            <a href="mailto:{{ site.email }}">{{ site.email }}</a>
          </div>
        </div>
        
        <div class="contact-info__item">
          <div class="contact-info__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div class="contact-info__text">
            <strong>Location</strong>
            <span>{{ site.location }}</span>
          </div>
        </div>
        
        <div class="contact-info__item">
          <div class="contact-info__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          </div>
          <div class="contact-info__text">
            <strong>LinkedIn</strong>
            <a href="{{ site.linkedin }}" target="_blank" rel="noopener">Connect with Steve →</a>
          </div>
        </div>
        
        <div style="margin-top: var(--space-2xl); padding-top: var(--space-xl); border-top: 1px solid rgba(255,255,255,0.1);">
          <h4 style="color: #fff; font-size: 1rem; margin-bottom: var(--space-sm);">Prefer to talk?</h4>
          <p style="color: var(--color-text-on-dark-muted); font-size: 0.9rem; margin: 0;">
            Book a 30-minute introductory call directly by reaching out via email with your preferred times.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Pre-fill service from query param
  const urlParams = new URLSearchParams(window.location.search);
  const serviceParam = urlParams.get('service');
  if (serviceParam) {
    const serviceSelect = document.getElementById('contact-service');
    if (serviceSelect) serviceSelect.value = serviceParam;
  }
  
  // Pre-fill assessment score from query param
  const scoreParam = urlParams.get('score');
  if (scoreParam) {
    const scoreField = document.getElementById('assessment-score-field');
    if (scoreField) scoreField.value = scoreParam;
  }
</script>
